<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>⚡ Cyber Radio Recorder</title>
    <!-- Библиотека для кодирования в MP3 из CDN -->
    <script src="https://cloudflare.com"></script>
    <style>
        :root {
            --bg-color: #0f172a;
            --card-bg: #1e293b;
            --accent-neon: #00f2fe;
            --accent-record: #ff0844;
            --text-main: #f8fafc;
        }

        body {
            font-family: 'Segoe UI', Roboto, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }

        .player-container {
            background: var(--card-bg);
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            width: 350px;
            text-align: center;
            border: 1px solid #334155;
        }

        h2 { margin-top: 0; font-size: 24px; letter-spacing: 1px; }

        .select-box {
            width: 100%;
            padding: 12px;
            background: #0f172a;
            color: white;
            border: 1px solid #475569;
            border-radius: 10px;
            font-size: 16px;
            margin-bottom: 20px;
            outline: none;
            cursor: pointer;
        }

        .visualizer {
            height: 50px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 4px;
            margin-bottom: 10px;
        }

        .bar {
            width: 6px;
            height: 5px;
            background: var(--accent-neon);
            border-radius: 3px;
            transition: height 0.1s ease;
        }

        .playing .bar {
            animation: bounce 1.2s ease-in-out infinite alternate;
        }
        .playing .bar:nth-child(2) { animation-delay: 0.2s; }
        .playing .bar:nth-child(3) { animation-delay: 0.4s; }
        .playing .bar:nth-child(4) { animation-delay: 0.6s; }
        .playing .bar:nth-child(5) { animation-delay: 0.1s; }

        @keyframes bounce {
            0% { height: 5px; }
            100% { height: 40px; }
        }

        /* Стиль для таймера записи */
        .timer-display {
            font-size: 22px;
            font-family: monospace;
            color: #64748b;
            margin-bottom: 20px;
            font-weight: bold;
            transition: color 0.3s ease;
        }

        .timer-active {
            color: var(--accent-record);
            animation: pulse 1s infinite alternate;
        }

        @keyframes pulse {
            0% { opacity: 0.7; }
            100% { opacity: 1; }
        }

        .controls {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        button {
            font-size: 16px;
            font-weight: 600;
            padding: 14px;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-play { background: linear-gradient(135deg, #00f2fe, #4facfe); color: #000; }
        .btn-record { background: linear-gradient(135deg, #ff0844, #ffb199); color: white; }
        .btn-stop { background: #475569; color: white; }

        button:hover:not(:disabled) { transform: translateY(-2px); opacity: 0.9; }
        button:disabled { background: #334155; color: #64748b; cursor: not-allowed; transform: none; }

        #status {
            margin-top: 20px;
            font-size: 14px;
            color: #94a3b8;
            font-style: italic;
        }
    </style>
</head>
<body>

<div class="player-container">
    <h2>📻 CYBER RADIO</h2>
    
    <select id="station-select" class="select-box">
        <option value="https://radiostation.ru">Radio Record (Танцевальное)</option>
        <option value="https://hostingradio.ru">Ретро ФМ</option>
        <option value="https://radiostation.ru">Хит ФМ</option>
    </select>

    <div id="visualizer" class="visualizer">
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
    </div>

    <!-- Блок отображения таймера -->
    <div id="timer" class="timer-display">00:00</div>

    <audio id="radio-stream" crossorigin="anonymous"></audio>

    <div class="controls">
        <button id="play-btn" class="btn-play">▶ Воспроизвести</button>
        <button id="start-rec" class="btn-record" disabled>🔴 Записать в MP3</button>
        <button id="stop-rec" class="btn-stop" disabled>⏹ Остановить и скачать</button>
    </div>

    <div id="status">Статус: Готов к запуску</div>
</div>

<script>
    const audio = document.getElementById('radio-stream');
    const stationSelect = document.getElementById('station-select');
    const playBtn = document.getElementById('play-btn');
    const startRecBtn = document.getElementById('start-rec');
    const stopRecBtn = document.getElementById('stop-rec');
    const statusDiv = document.getElementById('status');
    const visualizer = document.getElementById('visualizer');
    const timerDiv = document.getElementById('timer');

    let audioContext;
    let processor;
    let mp3Encoder;
    let mp3Data = [];
    let isRecording = false;

    // Переменные для работы таймера
    let startTime;
    let timerInterval;

    audio.src = stationSelect.value;

    stationSelect.addEventListener('change', () => {
        const wasPlaying = !audio.paused;
        if (isRecording) stopRecording();
        
        audio.src = stationSelect.value;
        if (wasPlaying) {
            audio.play();
        } else {
            resetUI();
        }
    });

    playBtn.addEventListener('click', () => {
        if (audio.paused) {
            audio.play().then(() => {
                playBtn.textContent = '⏸ Пауза';
                startRecBtn.disabled = false;
                visualizer.classList.add('playing');
                statusDiv.textContent = 'Статус: Прямой эфир...';
                initAudioEngine();
            }).catch(err => {
                statusDiv.textContent = 'Ошибка доступа к потоку.';
                console.error(err);
            });
        } else {
            if (isRecording) stopRecording();
            audio.pause();
            resetUI();
        }
    });

    function resetUI() {
        playBtn.textContent = '▶ Воспроизвести';
        startRecBtn.disabled = true;
        stopRecBtn.disabled = true;
        visualizer.classList.remove('playing');
        statusDiv.textContent = 'Статус: Пауза';
        resetTimer();
    }

    function initAudioEngine() {
        if (audioContext) return;

        audioContext = new (window.AudioContext || window.webkitAudioContext)();
        const source = audioContext.createMediaElementSource(audio);
        
        processor = audioContext.createScriptProcessor(4096, 2, 2);

        processor.onaudioprocess = (e) => {
            if (!isRecording) return;

            const left = e.inputBuffer.getChannelData(0);
            const right = e.inputBuffer.getChannelData(1);

            const leftInt16 = convertFloat32ToInt16(left);
            const rightInt16 = convertFloat32ToInt16(right);

            const mp3buf = mp3Encoder.encodeBuffer(leftInt16, rightInt16);
            if (mp3buf.length > 0) {
                mp3Data.push(mp3buf);
            }
        };

        source.connect(processor);
        processor.connect(audioContext.destination);
        source.connect(audioContext.destination);
    }

    function convertFloat32ToInt16(buffer) {
        let l = buffer.length;
        let buf = new Int16Array(l);
        while (l--) {
            let s = Math.max(-1, Math.min(1, buffer[l]));
            buf[l] = s < 0 ? s * 0x8000 : s * 0x7FFF;
        }
        return buf;
    }

    // Запуск таймера
    function startTimer() {
        startTime = Date.now();
        timerDiv.classList.add('timer-active');
        timerInterval = setInterval(() => {
            const elapsedTime = Date.now() - startTime;
            const totalSeconds = Math.floor(elapsedTime / 1000);
            const minutes = Math.floor(totalSeconds / 60).toString().padStart(2, '0');
            const seconds = (totalSeconds % 60).toString().padStart(2, '0');
            timerDiv.textContent = `${minutes}:${seconds}`;
        }, 1000);
    }

    // Сброс таймера
    function resetTimer() {
        clearInterval(timerInterval);
        timerDiv.textContent = '00:00';
        timerDiv.classList.remove('timer-active');
    }

    // Старт записи
    startRecBtn.addEventListener('click', () => {
        mp3Encoder = new lamejs.Mp3Encoder(2, 44100, 128);
        mp3Data = [];
        isRecording = true;

        startRecBtn.disabled = true;
        stopRecBtn.disabled = false;
        stationSelect.disabled = true;
        statusDiv.textContent = '🔴 Запись запущена...';
        
        startTimer(); // Включаем таймер
    });

    // Остановка записи
    stopRecBtn.addEventListener('click', () => {
        stopRecording();
    });

    function stopRecording() {
        if (!isRecording) return;
        isRecording = false;

        resetTimer(); // Выключаем и сбрасываем таймер

