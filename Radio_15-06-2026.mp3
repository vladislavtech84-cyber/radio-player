143646 .tn-elem[data-elem-id="1695733963736"] .tn-atom{white-space:normal;background-size:cover;}}@media screen and (max-width:639px){#rec641143646 .tn-elem[data-elem-id="1695733963736"]{display:table;top:843px;;left:calc(50% - 240px + 8px);;width:px;height:auto;}#rec641143646 .tn-elem[data-elem-id="1695733963736"] .tn-atom{white-space:normal;background-size:cover;}}@media screen and (max-width:479px){#rec641143646 .tn-elem[data-elem-id="1695733963736"]{display:table;top:851px;;left:calc(50% - 160px + 10px);;width:191px;height:auto;}#rec641143646 .tn-elem[data-elem-id="1695733963736"] .tn-atom{white-space:normal;font-size:10px;background-size:cover;}}</style> <div class='t396'> <div class="t396__artboard" data-artboard-recid="641143646" data-artboard-screens="320,480,640,960,1200" data-artboard-height="1693" data-artboard-valign="center" data-artboard-upscale="grid" data-artboard-height-res-320="2414" data-artboard-height-res-480="2491" data-artboard-height-res-640="2647" data-artboard-height-res-960="1823"> <div class="t396__carrier" data-artboard-recid="641143646"></div> <div class="t396__filter" data-artboard-recid="641143646"></div> <div class='t396__elem tn-elem tn-elem__6411436461694958454403' data-elem-id='1694958454403' data-elem-type='text' data-field-top-value="100" data-field-left-value="20" data-field-height-value="42" data-field-width-value="212" data-field-axisy-value="top" data-field-axisx-value="left" data-field-container-value="grid" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="px" data-field-widthunits-value="px" data-field-textfit-value="autoheight" data-field-fontsize-value="32" data-field-top-res-320-value="60" data-field-fontsize-res-320-value="24" data-field-top-res-480-value="70" data-field-fontsize-res-480-value="26" data-field-top-res-640-value="90" data-field-fontsize-res-640-value="30" data-field-left-res-960-value="10"> <div class='tn-atom'field='tn_text_1694958454403'>О компании</div> </div> <div class='t396__elem tn-elem tn-elem__6411436461694958454408' data-elem-id='1694958454408' data-elem-type='text' data-field-top-value="202" data-field-left-value="20" data-field-height-value="400" data-field-width-value="560" data-field-axisy-value="top" data-field-axisx-value="left" data-field-container-value="grid" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="px" data-field-widthunits-value="px" data-field-textfit-value="autoheight" data-field-fontsize-value="18" data-field-top-res-320-value="115" data-field-width-res-320-value="300" data-field-fontsize-res-320-value="14" data-field-top-res-480-value="134" data-field-width-res-480-value="460" data-field-fontsize-res-480-value="16" data-field-top-res-640-value="161" data-field-width-res-640-value="620" data-field-fontsize-res-640-value="16" data-field-top-res-960-value="182" data-field-left-res-960-value="10" data-field-width-res-960-value="461"> <div class='tn-atom'field='tn_text_1694958454408'><span style="color: rgb(230, 26, 36);">Мы&nbsp;занимаемся радио 18 лет. Поэтому точно знаем, как подобрать оптимальное решение по&nbsp;запуску интернет-радиостанции и&nbsp;быстро его реализовать. </span><br /><br />Клиенту не&nbsp;нужно тратить время и&nbsp;силы, чтобы перебирать варианты по&nbsp;оборудованию и&nbsp;программному обеспечению, пробовать и&nbsp;тестировать их.<br /><br />Организуем вещание выгоднее, чем если<br />бы&nbsp;вы&nbsp;занимались этим сами. Зачем покупать гараж<br />под тостер, если можно арендовать для&nbsp;него полку?<br /><br />Так и&nbsp;с&nbsp;нашим предложением: занимайтесь творческой частью вещания, а&nbsp;техническое оснащение используйте наше. Так будет намного дешевле и&nbsp;удобнее.</div> </div> <div class='t396__elem tn-elem tn-elem__6411436461694958454436' data-elem-id='1694958454436' data-elem-type='shape' data-field-top-value="692" data-field-left-value="0" data-field-height-value="415" data-field-width-value="100" data-field-axisy-value="top" data-field-axisx-value="left" data-field-container-value="window" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="px" data-field-widthunits-value="%" data-field-top-res-320-value="1025" data-field-height-res-320-value="657" data-field-width-res-320-value="99" data-field-top-res-480-value="1047" data-field-height-res-480-value="626" data-field-top-res-640-value="1191" data-field-left-res-640-value="0" data-field-height-res-640-value="472" data-field-top-res-960-value="732" data-field-left-res-960-value="0" data-field-height-res-960-value="454"> <div class='tn-atom'> </div> </div> <div class='t396__elem tn-elem tn-elem__6411436461694958454439' data-elem-id='1694958454439' data-elem-type='text' data-field-top-value="762" data-field-left-value="620" data-field-height-value="125" data-field-width-value="560" data-field-axisy-value="top" data-field-axisx-value="left" data-field-container-value="grid" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="px" data-field-widthunits-value="px" data-field-textfit-value="autoheight" data-field-fontsize-value="18" data-field-top-res-320-value="1425" data-field-width-res-320-value="300" data-field-fontsize-res-320-value="14" data-field-top-res-480-value="1415" data-field-width-res-480-value="460" data-field-top-res-640-value="1498" data-field-left-res-640-value="10" data-field-width-res-640-value="486" data-field-fontsize-res-640-value="16" data-field-top-res-960-value="797" data-field-left-res-960-value="489" data-field-width-res-960-value="460"> <div class='tn-atom'field='tn_text_1694958454439'>У&nbsp;нас работают все необходимые для&nbsp;радиовещания специалисты, поэтому мы&nbsp;обеспечиваем полный цикл техподдержки. Вы&nbsp;не&nbsp;тратите ресурсы на&nbsp;содержание своего персонала, которые обеспечивают и&nbsp;сопровождают интернет-трансляции.</div> </div> <div class='t396__elem tn-elem tn-elem__6411436461694958454441' data-elem-id='1694958454441' data-elem-type='text' data-field-top-value="762" data-field-left-value="20" data-field-height-value="275" data-field-width-value="560" data-field-axisy-value="top" data-field-axisx-value="left" data-field-container-value="grid" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="px" data-field-widthunits-value="px" data-field-textfit-value="autoheight" data-field-fontsize-value="18" data-field-top-res-320-value="1075" data-field-width-res-320-value="300" data-field-fontsize-res-320-value="14" data-field-top-res-480-value="1097" data-field-width-res-480-value="460" data-field-fontsize-res-480-value="16" data-field-top-res-640-value="1246" data-field-left-res-640-value="10" data-field-width-res-640-value="620" data-field-fontsize-res-640-value="16" data-field-top-res-960-value="797" data-field-left-res-960-value="10" data-field-width-res-960-value="460"> <div class='tn-atom'field='tn_text_1694958454441'>Наши технические специалисты разбираются во&nbsp;всех видах вещательного оборудования, используемого в&nbsp;радио индустрии. Если нет возможности заниматься настройками самостоятельно, просто дайте доступ, инженеры подключатся и&nbsp;все сделают даже на&nbsp;вашей стороне. При этом не&nbsp;будут вас парить сложными терминами и&nbsp;понятиями.<br /><br />Сервисы и&nbsp;ресурсы нашей компании защищены по&nbsp;промышленным ИТ-стандартам, стриминг аудио изолирован от&nbsp;внешних угроз и&nbsp;кибер-вмешательства.</div> </div> <div class='t396__elem tn-elem tn-elem__6411436461694958454442' data-elem-id='1694958454442' data-elem-type='shape' data-field-top-value="877" data-field-left-value="1020" data-field-height-value="229" data-field-width-value="280" data-field-axisy-value="top" data-field-axisx-value="left" data-field-container-value="grid" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="px" data-field-widthunits-value="px" data-field-top-res-320-value="1579" data-field-left-res-320-value="196" data-field-height-res-320-value="103" data-field-width-res-320-value="124" data-field-top-res-480-value="1533" data-field-left-res-480-value="312" data-field-top-res-640-value="1523" data-field-left-res-640-value="470" data-field-height-res-640-value="140" data-field-width-res-640-value="169" data-field-top-res-960-value="991" data-field-left-res-960-value="755" data-field-height-res-960-value="195" data-field-width-res-960-value="237"> <div class='tn-atom t-bgimg' data-original="https://static.tildacdn.com/tild6564-6562-4934-b530-613633333666/Mask_group.png"
aria-label='' role="img"> </div> </div> <div class='t396__elem tn-elem tn-elem__6411436461694958454452' data-elem-id='1694958454452' data-elem-type='text' data-field-top-value="1177" data-field-left-value="620" data-field-height-value="300" data-field-width-value="560" data-field-axisy-value="top" data-field-axisx-value="left" data-field-container-value="grid" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="px" data-field-widthunits-value="px" data-field-textfit-value="autoheight" data-field-fontsize-value="18" data-field-top-res-320-value="1994" data-field-width-res-320-value="300" data-field-fontsize-res-320-value="14" data-field-top-res-480-value="2135" data-field-left-res-480-value="10" data-field-width-res-480-value="460" data-field-fontsize-res-480-value="16" data-field-top-res-640-value="2244" data-field-left-res-640-value="8" data-field-width-res-640-value="620" data-field-top-res-960-value="1236" data-field-left-res-960-value="489" data-field-width-res-960-value="462"> <div class='tn-atom'field='tn_text_1694958454452'>Наш руководитель Алексей Нестеренко всегда доступен и&nbsp;открыт к&nbsp;диалогу. Он&nbsp;с&nbsp;удовольствием проконсультирует, обсудит технические задачи<br />и&nbsp;подскажет выгодное для&nbsp;вас решение.<br /><br />Он&nbsp;основал компанию Микро-ИТ и&nbsp;с&nbsp;нуля создал вещательную инфраструктуру, поэтому знает все тонкости работы. Собрал команду профессионалов<br />с&nbsp;разными навыками, чтобы предлагать радио отрасли современные технологичные сервисы. Сейчас Алексей управляет разработкой новых продуктов для&nbsp;радио<br />и&nbsp;занимается их&nbsp;продвижением.</div> </div> <div class='t396__elem tn-elem tn-elem__6411436461694958642677' data-elem-id='1694958642677' data-elem-type='shape' data-field-top-value="216" data-field-left-value="619" data-field-height-value="406" data-field-width-value="560" data-field-axisy-value="top" data-field-axisx-value="left" data-field-container-value="grid" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="px" data-field-widthunits-value="px" data-field-top-res-320-value="625" data-field-left-res-320-value="10" data-field-height-res-320-value="216" data-field-width-res-320-value="300" data-field-top-res-480-value="544" data-field-height-res-480-value="333" data-field-width-res-480-value="460" data-field-top-res-640-value="551" data-field-left-res-640-value="10" data-field-height-res-640-value="450" data-field-width-res-640-value="620" data-field-top-res-960-value="196" data-field-left-res-960-value="489" data-field-height-res-960-value="338" data-field-width-res-960-value="464"> <div class='tn-atom t-bgimg' data-original="https://static.tildacdn.com/tild3838-3531-4661-b764-633434343965/Group_2145.png"
